let users;
let cookiesAccepted = false;
let apiCalls = [];


describe("Select Customer", () => {
    before(() => {
        cy.fixture("updatedUsers").then((data) => {
            users = data;
        });

        // Intercept all GET and POST requests to the specified URL pattern
        cy.intercept('https://qa-api.xxxxxxxx.com/*', (req) => {
            req.on('response', (res) => {
                cy.captureApiCall(req, res);
            });
        }).as('apiCalls');
    });

    beforeEach(() => {
        cy.clearCookies();
        cy.clearLocalStorage();
    });

    after(() => {
        // Save the captured API calls to a JSON file
        console.log('Writing API calls to JSON file', apiCalls);
        cy.writeFile('cypress/fixtures/apiCalls.json', apiCalls)
            .then(() => {
                console.log('API calls successfully written to apiCalls.json');
            });
    });

    it("Select customer", () => {
        cy.login(
            "xxxxxxxxxx@yyyy.com",
            "zz",
            0,
            cookiesAccepted
        );

        cy.wait(5000);

        cy.get('#cwc-sidenav-component > #entitySelector').find('.cwc-entity-selector__id').click();
      
        cy.get('#cwc-sidenav-component').find('.cwc-entity-selector-item__name').contains('Miller Homes Ltd - North East').click();
    });
});

