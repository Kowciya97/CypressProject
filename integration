let users;
let cookiesAccepted = false;

describe('Login Test', () => {
    before(() => {
        cy.fixture('allUsers').then((data) => {
            users = data;
        });
    });

    beforeEach(() => {
        cy.clearCookies();
        cy.clearLocalStorage();
    });

    it('logs in and checks the welcome message for a specific country', () => {
        const countryCode = 'zz'; // Change this to the country code you want to test
        const countryUsers = users[countryCode] || [];

        countryUsers.forEach((user, index) => {
            if (!user.Password) {
                // Skip users with null passwords
                return;
            }
            cy.intercept('POST', 'https://qa-api.xxxxxxxx.com/v6/secm/oam/oauth2/token').as('token')
            // Visit the login page
            cy.visit(Cypress.env('url'));

            // Accept cookies only once
            if (!cookiesAccepted) {
                cy.get('#CybotCookiebotDialogBodyLevelButtonLevelOptinAllowAll').click({ force: true });
                cookiesAccepted = true;
            }

            // Perform login steps
            cy.get('#cwc-input-0').type(user.UserAccount);
            cy.get('#cwc-input-1').type(user.Password);
            cy.get('#cmx-login-form-submit-btn').click();

            cy.wait('@token')

            cy.wait(6000)
            // Check if the error message is displayed
            cy.get('h1').then(e => {
                const headerText = e[0].text();
                // Welcome to XXXXXX
                if (headerText.includes('Welcome to XXXXXX')) {
                    cy.log('LOGGED IN');
                    const updatedUser = { ...user, active: true, updated: new Date().toISOString() };
                    cy.task('updateUserJson', { countryCode, index, updatedUser });
                } else {
                    cy.log('NOT LOGGED IN');
                    const updatedUser = { ...user, active: false, updated: new Date().toISOString(), note: "user or password incorrect" };
                    cy.task('updateUserJson', { countryCode, index, updatedUser });
                }
            });
        });
    });
});

